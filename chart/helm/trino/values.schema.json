          "type": "string",
          "default": "",
          "description": "Extra worker configuration"
        },
        "coordinatorExtraConfig": {
          "type": "string",
          "description": "Extra coordinator configuration"
        },
        "autoscaling": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false,
              "description": "Enable horizontal pod autoscaling"
            },
            "maxReplicas": {
              "type": "integer",
              "default": 5,
              "description": "Maximum replicas for autoscaling"
            },
            "targetCPUUtilizationPercentage": {
              "type": "integer",
              "default": 50,
              "description": "Target CPU utilization percentage"
            },
            "targetMemoryUtilizationPercentage": {
              "type": "integer",
              "default": 80,
              "description": "Target memory utilization percentage"
            },
            "behavior": {
              "type": "object",
              "default": {},
              "description": "Configuration for scaling up and down"
            }
          }
