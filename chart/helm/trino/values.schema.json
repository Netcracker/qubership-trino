            "pollingInterval": {
              "type": "integer",
              "default": 30,
              "description": "Polling interval in seconds"
            },
            "cooldownPeriod": {
              "type": "integer",
              "default": 300,
              "description": "Cooldown period in seconds"
            },
            "initialCooldownPeriod": {
              "type": "integer",
              "default": 0,
              "description": "Initial cooldown period in seconds"
            },
            "minReplicaCount": {
              "type": "integer",
              "default": 0,
              "description": "Minimum replica count"
            },
            "maxReplicaCount": {
              "type": "integer",
              "default": 5,
              "description": "Maximum replica count"
            },
            "fallback": {
              "type": "object",
              "default": {},
              "description": "Fallback options if scaler is in error state"
